<% include partials/header.ejs %>

<div class="container mt-4">
  <div class="row">
    <div class="col-12">
      <h1>Silly Memory Game</h1>
      <p>Match the pairs of silly emojis! The game tracks your moves and time.</p>
      
      <div class="d-flex justify-content-between align-items-center mb-3">
        <div class="moves-counter">
          <strong>Moves: <span id="moves">0</span></strong>
        </div>
        <div class="timer">
          <strong>Time: <span id="timer">0</span>s</strong>
        </div>
        <button id="restart-btn" class="btn btn-primary">Restart Game</button>
      </div>
      
      <div id="game-board" class="game-board"></div>
      
      <div id="game-message" class="alert alert-info mt-3 text-center" style="display: none;">
        <span id="message-text"></span>
      </div>
    </div>
  </div>
</div>

<% include partials/footer.ejs %>