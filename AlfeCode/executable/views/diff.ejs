<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <title>Diff: <%= gitRepoNameCLI %></title>
    <link id="favicon" rel="icon" href="/alfe_favicon.ico" />
    <link rel="alternate icon" href="/alfe_favicon.ico" type="image/x-icon" />
    <link rel="stylesheet" href="/styles.css" />
    <link rel="stylesheet" href="/CSS/chat.css" />
    <style>
        :root {
            --bg: #020617;
            --panel: #0f172a;
            --panel-soft: #111827;
            --border: #1e293b;
            --border-strong: #334155;
            --text: #e5e7eb;
            --muted: #94a3b8;
            --success: #22c55e;
            --added: rgba(16, 185, 129, 0.12);
            --removed: rgba(248, 113, 113, 0.16);
            --meta: rgba(245, 158, 11, 0.18);
            --shadow: 0 16px 40px rgba(15, 23, 42, 0.7);
        }

        * {
            box-sizing: border-box;
        }

        body.is-resizing,
        body.is-resizing * {
            cursor: col-resize !important;
        }

        body {
            margin: 0;
            min-height: 100vh;
            display: flex;
            align-items: stretch;
            justify-content: center;
            background: radial-gradient(circle at top left, rgba(59, 130, 246, 0.12), transparent 55%),
                radial-gradient(circle at top right, rgba(139, 92, 246, 0.12), transparent 60%),
                var(--bg);
            color: var(--text);
            font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        }

        .page {
            margin: 0;
            max-width: none;
            width: 100%;
            background: var(--panel);
            border-radius: 0;
            padding: 16px 16px 22px;
            display: flex;
            flex-direction: column;
            gap: 14px;
            box-shadow: var(--shadow);
            border: 1px solid var(--border);
        }

        .header-row {
            display: flex;
            flex-wrap: nowrap;
            gap: 12px;
            justify-content: space-between;
            align-items: flex-start;
        }

        .header-main {
            display: flex;
            flex-direction: column;
            gap: 12px;
            flex: 1 1 auto;
            min-width: 0;
        }

        .header-actions {
            flex: 0 0 auto;
            display: flex;
            justify-content: flex-end;
            align-items: flex-start;
            min-width: 0;
            margin-left: auto;
        }

        .revision-info {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            font-size: 12px;
            color: var(--muted);
        }

        .revision-pill {
            background: rgba(255, 255, 255, 0.04);
            border: 1px solid var(--border);
            border-radius: 10px;
            padding: 6px 10px;
            color: var(--text);
            font-weight: 600;
            min-width: 200px;
        }

        .revision-pill .sub {
            display: block;
            margin-top: 4px;
            font-weight: 400;
            color: var(--muted);
        }

        .toolbar {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 12px;
            color: var(--muted);
        }

        .toolbar button {
            border-radius: 999px;
            border: 1px solid var(--border);
            padding: 6px 14px;
            background: #0b1324;
            color: var(--muted);
            font-size: 12px;
            cursor: pointer;
        }

        .toolbar button.active {
            background: #1d4ed8;
            color: #fff;
            border-color: #2563eb;
        }

        .read-only-prompt-row {
            margin-bottom: 8px;
            display: flex;
            align-items: center;
            gap: 8px;
            flex-wrap: wrap;
        }
        .read-only-prompt-label {
            font-size: 10px;
            letter-spacing: 0.08em;
            color: var(--muted);
            text-transform: uppercase;
        }
        .read-only-prompt-input {
            flex: 1 1 auto;
            min-width: 0;
            background: #0b1324;
            border: 1px solid var(--border);
            border-radius: 10px;
            color: var(--text);
            padding: 8px 10px;
            font-size: 13px;
            font-family: inherit;
        }

        .final-output-block {
            margin-top: 12px;
            padding: 12px 14px;
            border-radius: 12px;
            background: #0b1324;
            border: 1px solid var(--border);
        }

        .final-output-label {
            display: block;
            font-size: 10px;
            font-weight: 600;
            color: var(--muted);
            margin-bottom: 8px;
            text-transform: uppercase;
            letter-spacing: 0.08em;
        }

        .final-output-text {
            white-space: pre-wrap;
            color: var(--text);
            font-size: 13px;
            line-height: 1.5;
            margin: 0;
        }

        .commit-message-box {
            background: var(--panel-soft);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 12px 14px;
            box-shadow: var(--shadow);
        }

        .commit-message-title {
            margin: 0 0 6px;
            font-size: 13px;
            color: var(--muted);
            letter-spacing: 0.01em;
        }


        .diff-followup-form {
            margin-top: 12px;
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .diff-followup-label {
            font-size: 10px;
            letter-spacing: 0.08em;
            color: var(--muted);
            text-transform: uppercase;
        }

        .diff-followup-input {
            width: 100%;
            min-height: 64px;
            background: #0b1324;
            border: 1px solid var(--border);
            border-radius: 10px;
            color: var(--text);
            padding: 10px 12px;
            font-size: 13px;
            font-family: inherit;
            resize: vertical;
        }

        .diff-followup-actions {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .diff-followup-submit {
            margin-left: auto;
            padding: 10px;
            width: 44px;
            height: 44px;
            border-radius: 999px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, var(--accent) 0%, var(--accent-strong) 100%);
            color: #fff;
            border: none;
            box-shadow: 0 16px 32px rgba(124, 58, 237, 0.35);
            cursor: pointer;
            transition: transform 0.18s ease, box-shadow 0.18s ease;
        }

        .diff-followup-submit svg {
            width: 20px;
            height: 20px;
        }

        .diff-followup-submit:hover {
            transform: translateY(-2px);
            box-shadow: 0 24px 40px rgba(124, 58, 237, 0.38);
        }

        .diff-followup-status {
            flex: 1;
            font-size: 12px;
            color: var(--muted);
        }

        @media (max-width: 960px) {
            .header-row {
                flex-wrap: wrap;
            }

            .header-actions {
                width: 100%;
                justify-content: flex-start;
            }
        }

        .merge-button-wrapper {
            position: relative;
            display: inline-flex;
        }

        .merge-button-wrapper .merge-disabled-tooltip {
            position: absolute;
            bottom: calc(100% + 8px);
            left: 50%;
            transform: translate(-50%, 6px);
            background: rgba(15, 23, 42, 0.95);
            padding: 9px 12px;
            border-radius: 10px;
            border: 1px solid var(--border);
            color: var(--text);
            box-shadow: 0 12px 28px rgba(15, 23, 42, 0.35);
            font-size: 12px;
            white-space: nowrap;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.15s ease, transform 0.15s ease;
            z-index: 10;
        }

        .merge-button-wrapper.is-merge-disabled:hover .merge-disabled-tooltip {
            opacity: 1;
            transform: translate(-50%, 0);
        }

        #mergeButton {
            border-radius: 999px;
            border: 1px solid rgba(255, 255, 255, 0.08);
            padding: 10px 20px;
            background: rgba(255, 255, 255, 0.05);
            color: rgba(230, 230, 230, 0.95);
            font-weight: 700;
            letter-spacing: 0.01em;
            box-shadow: none;
            transition: transform 0.18s ease, box-shadow 0.18s ease, background 0.18s ease, color 0.18s ease;
            display: inline-flex;
            align-items: center;
            gap: 10px;
            min-height: 40px;
            margin-right: 50px;
        }
        #mergeButton svg { opacity: 0.95; }
        #mergeButton:enabled:hover {
            transform: translateY(-1px);
            box-shadow: 0 16px 32px rgba(124, 58, 237, 0.32);
        }
        #mergeButton.is-merge-ready {
            background: linear-gradient(135deg, rgba(124, 58, 237, 0.95), rgba(139, 92, 246, 0.95));
            color: #fff;
            border-color: transparent;
            box-shadow: 0 12px 26px rgba(124, 58, 237, 0.35);
        }
        .merge-button-wrapper.is-merge-disabled #mergeButton {
            background: rgba(255, 255, 255, 0.04);
            color: var(--muted);
            border-color: var(--border);
            box-shadow: none;
        }

        .alert {
            margin: 0;
            padding: 12px 14px;
            border-radius: 10px;
            background: rgba(249, 115, 22, 0.18);
            border: 1px solid rgba(249, 115, 22, 0.35);
            color: #fed7aa;
        }

        .open-in-editor-button {
            background: transparent;
            border: none;
            color: var(--muted);
            cursor: pointer;
            padding: 6px;
            border-radius: 6px;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            position: absolute;
            top: 12px;
            right: 12px;
        }
        .open-in-editor-button:hover { color: #fff; background: rgba(255,255,255,0.03); }

        .diff-shell {
            display: grid;
            grid-template-columns: var(--diff-sidebar-width, clamp(280px, 26vw, 720px)) 10px minmax(0, 1fr);
            gap: 0;
            min-height: 360px;
            min-width: 0;
        }

        .diff-sidebar {
            display: flex;
            flex-direction: column;
            gap: 12px;
            align-self: flex-start;
            min-width: 0;
            padding-right: 10px;
        }

        .diff-sidebar-resizer {
            width: 10px;
            cursor: col-resize;
            border-radius: 999px;
            background: transparent;
            position: relative;
        }

        .diff-sidebar-resizer::before {
            content: "";
            position: absolute;
            top: 8px;
            bottom: 8px;
            left: 3px;
            width: 4px;
            border-radius: 999px;
            background: rgba(148, 163, 184, 0.24);
            transition: background 0.2s ease;
        }

        .diff-sidebar-resizer:hover::before,
        body.is-resizing .diff-sidebar-resizer::before {
            background: rgba(96, 165, 250, 0.8);
        }

        .sidebar-context-card {
            background: var(--panel-soft);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 12px;
            box-shadow: var(--shadow);
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .sidebar-context-item {
            display: flex;
            flex-direction: column;
            gap: 6px;
            min-width: 0;
        }

        .sidebar-context-label {
            font-size: 10px;
            letter-spacing: 0.08em;
            color: var(--muted);
            text-transform: uppercase;
        }

        .sidebar-context-value {
            margin: 0;
            white-space: pre-wrap;
            word-break: break-word;
            color: var(--text);
            font-size: 13px;
            line-height: 1.5;
        }

        .commit-list {
            background: var(--panel-soft);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 12px;
            overflow: hidden;
            box-shadow: var(--shadow);
            display: flex;
            flex-direction: column;
            gap: 10px;
            align-self: stretch;
            width: 100%;
            min-width: 0;
        }

        .commit-list h4 {
            margin: 0;
            font-size: 14px;
        }

        .commit-list ul {
            list-style: none;
            padding: 0;
            margin: 0;
            display: flex;
            flex-direction: column;
            gap: 6px;
        }

        .commit-list button {
            width: 100%;
            text-align: left;
            background: #0b1324;
            border: 1px solid var(--border);
            color: var(--text);
            font-size: 12px;
            padding: 8px 10px;
            border-radius: 8px;
            cursor: pointer;
            transition: background 0.2s ease, transform 0.15s ease;
            display: flex;
            flex-direction: column;
            gap: 4px;
            min-width: 0;
            overflow: hidden;
        }

        .commit-list button:hover {
            background: rgba(59, 130, 246, 0.18);
            transform: translateX(2px);
        }

        .commit-list button.active {
            background: rgba(59, 130, 246, 0.3);
            border-color: #2563eb;
        }

        .commit-list .commit-hash {
            font-family: "JetBrains Mono", "Fira Code", ui-monospace, SFMono-Regular, monospace;
            font-size: 11px;
            color: var(--muted);
        }

        .commit-list .commit-message {
            font-size: 12px;
            color: var(--text);
            line-height: 1.3;
            display: block;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            max-width: 100%;
        }

        .file-list {
            background: var(--panel-soft);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 12px;
            overflow: hidden;
            box-shadow: var(--shadow);
            flex: 1;
        }

        .file-list h4 {
            margin: 0 0 10px;
            font-size: 14px;
        }

        .file-list ul {
            list-style: none;
            padding: 0;
            margin: 0;
            display: flex;
            flex-direction: column;
            gap: 6px;
        }

        .file-list button {
            width: 100%;
            text-align: left;
            background: #0b1324;
            border: 1px solid var(--border);
            color: var(--text);
            font-size: 13px;
            padding: 8px 10px;
            border-radius: 8px;
            cursor: pointer;
            transition: background 0.2s ease, transform 0.15s ease;
        }

        .file-list button:hover {
            background: rgba(59, 130, 246, 0.18);
            transform: translateX(2px);
        }

        .file-list button.active {
            background: rgba(59, 130, 246, 0.3);
            border-color: #2563eb;
        }

        .file-list button .file-label {
            display: inline-block;
            max-width: calc(100% - 76px);
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
            vertical-align: top;
        }

        .file-list button .file-stats {
            margin-left: 8px;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            font-size: 11px;
            font-family: "JetBrains Mono", "Fira Code", ui-monospace, SFMono-Regular, monospace;
            color: var(--muted);
        }

        .file-list button .file-stats .additions {
            color: var(--success, #22c55e);
        }

        .file-list button .file-stats .deletions {
            color: #f87171;
        }

        .viewer-panel {
            background: #020617;
            border: 1px solid var(--border-strong);
            border-radius: 12px;
            box-shadow: var(--shadow);
            padding: 10px;
            display: flex;
            flex-direction: column;
            gap: 10px;
            min-width: 0;
        }

        .file-meta {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 12px;
            padding: 0 4px;
            color: var(--muted);
            font-size: 12px;
        }

        .diff-view {
            position: relative;
            flex: 1;
            min-height: auto;
            border-radius: 10px;
            border: none;
            background: transparent;
            overflow: visible;
            min-width: 0;
        }

        .diff-inner {
            min-width: 0;
            display: flex;
            flex-direction: column;
            gap: 24px;
            padding-bottom: 6px;
        }

        .diff-file-section {
            background: #050812;
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 16px;
            box-shadow: 0 20px 40px rgba(2, 6, 23, 0.6);
            position: relative;
        }

        .diff-file-section:focus-visible {
            outline: 2px solid rgba(59, 130, 246, 0.9);
            outline-offset: 3px;
        }

        .diff-file-header {
            display: flex;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 10px;
            align-items: center;
            color: var(--text);
            font-size: 14px;
            padding-right: 36px;
        }

        .diff-file-title {
            font-weight: 600;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
            flex: 1 1 0;
            min-width: 0;
        }

        .diff-file-viewer {
            background: #020617;
            border-radius: 10px;
            border: 1px solid var(--border);
            padding: 14px;
            overflow-x: auto;
            overflow-y: hidden;
            box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.04);
            width: 100%;
        }

        .diff-lines {
            font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
            font-size: 12px;
            display: flex;
            flex-direction: column;
            gap: 0;
            overflow-x: auto;
            overflow-y: visible;
            overscroll-behavior: contain;
            width: max-content;
            min-width: 100%;
        }

        .diff-header {
            position: sticky;
            top: 0;
            z-index: 1;
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            border-bottom: 1px solid var(--border);
            background: #0b1324;
            font-size: 11px;
            color: var(--muted);
        }

        .diff-header > div {
            padding: 6px 10px;
        }

        .diff-view.stacked .diff-header {
            grid-template-columns: minmax(0, 1fr);
        }

        .diff-view.stacked .diff-header > div:nth-child(2) {
            border-top: 1px solid var(--border);
        }

        .hunk {}

        .diff-view.side-by-side .hunk {
            display: grid;
            grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
        }

        .diff-view.stacked .hunk {
            display: block;
        }

        .diff-column {
            border-left: 1px solid var(--border);
        }

        .diff-column:first-child {
            border-left: none;
        }

        .diff-line {
            display: grid;
            grid-template-columns: 3.75rem minmax(0, 1fr);
            align-items: baseline;
            white-space: pre;
            line-height: 1.35;
            padding: 0 10px;
            width: max-content;
            min-width: 100%;
        }

        .line-num {
            padding-right: 8px;
            text-align: right;
            color: var(--muted);
            user-select: none;
            font-variant-numeric: tabular-nums;
        }

        .code {
            display: block;
            overflow: visible;
            min-width: max-content;
        }

        .line-sign {
            display: inline-block;
            width: 1ch;
            padding-right: 8px;
            font-weight: 700;
            font-family: inherit;
        }

        .diff-line.added .line-sign, .diff-line.changed-right .line-sign {
            color: #10b981;
        }
        .diff-line.removed .line-sign, .diff-line.changed-left .line-sign {
            color: #f87171;
        }
        .diff-line .line-sign {
            color: var(--muted);
        }

        .diff-line.added {
            background: var(--added);
        }

        .diff-line.removed {
            background: var(--removed);
        }

        .diff-line.changed-left {
            background: var(--removed);
        }

        .diff-line.changed-right {
            background: var(--added);
        }

        .diff-line.meta {
            background: var(--meta);
            color: #facc15;
            font-style: italic;
        }

        .diff-view.stacked .hunk {
            border-top: 1px solid var(--border);
        }

        .diff-view.stacked .hunk:first-child {
            border-top: none;
        }

        .diff-view.stacked .diff-column {
            border-left: none;
            border-top: 1px solid var(--border);
        }

        .diff-view.stacked .diff-column:first-child {
            border-top: none;
        }

        details.raw-diff {
            background: rgba(15, 23, 42, 0.8);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 14px 16px;
        }

        details.raw-diff pre {
            background: #0b1324;
            padding: 12px;
            border-radius: 8px;
            border: 1px solid var(--border);
            font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
            font-size: 12px;
            white-space: pre;
            overflow: auto;
            max-height: 420px;
        }

        @media (max-width: 1100px) {
            .diff-shell {
                grid-template-columns: 1fr;
                gap: 12px;
            }

            .diff-sidebar {
                padding-right: 0;
            }

            .diff-sidebar-resizer {
                display: none;
            }

            .commit-list {
                order: -2;
            }

            .file-list {
                order: -1;
            }

            .diff-inner {
                min-width: 520px;
            }
        }
    </style>
</head>
<body>
<%- include('partials/session_banner') %>
<% const resolvedModelDisplayName = typeof modelDisplayName === 'string' && modelDisplayName.trim() ? modelDisplayName.trim() : ''; %>
<div class="page">
    <div class="header-row">
        <div class="header-main">
            <% const comparisonPromptLineValue = typeof comparisonPromptLine === 'string' ? (comparisonPromptLine.trim().split(/\r?\n/)[0] || '') : ''; %>
<% const comparisonCommitMessage = (typeof compMeta !== 'undefined' && compMeta && (compMeta.fullMessage || compMeta.message)) ? (compMeta.fullMessage || compMeta.message) : ''; %>
<% const renderCommitList = typeof showCommitList !== 'undefined' ? !!showCommitList : false; %>
        </div>

        <div class="header-actions">
            <div class="merge-button-wrapper<%= mergeReady ? '' : ' is-merge-disabled' %>" id="mergeButtonWrapper">
                <button
                    type="button"
                    id="mergeButton"
                    class="nav-button<%= mergeReady ? ' is-merge-ready' : '' %>"
                    <%= mergeReady ? '' : 'disabled aria-disabled="true"' %>
                    title="<%= mergeReady ? 'Merge current branch into the configured parent branch' : 'Merge is available after agent finishes running.' %>"
                >
                    <svg aria-hidden="true" focusable="false" width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M18 3a2 2 0 11-4 0 2 2 0 014 0zM9 12a2 2 0 100-4 2 2 0 000 4zm7 7a2 2 0 100-4 2 2 0 000 4z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    <span id="mergeButtonText"><%= mergeReady ? 'Merge' : 'Merge Ready' %></span>
                </button>
            </div>
        </div>
    </div>

    <% if (typeof errorMessage !== 'undefined' && errorMessage) { %>
    <div class="alert" role="alert"><%= errorMessage %></div>
    <% } %>

    <div class="diff-shell">
        <div class="diff-sidebar">
            <div class="sidebar-context-card">
                <div class="sidebar-context-item">
                    <span class="sidebar-context-label">Target</span>
                    <span class="sidebar-context-value"><%= gitRepoNameCLI %></span>
                </div>
                <div class="sidebar-context-item">
                    <span class="sidebar-context-label">Comparison</span>
                    <span class="sidebar-context-value">
                        <% if (baseRev) { %>
                        <span class="revision-pill">
                            <span class="sub">Compared to</span>
                            <%= baseRev.slice(0, 7) %>
                        </span>
                        <% } %>
                        <% if (compRev) { %>
                        <span class="revision-pill">
                            <span class="sub">Comparison</span>
                            <%= compRev.slice(0, 7) %>
                        </span>
                        <% } %>
                    </span>
                </div>
            </div>
            <% if (renderCommitList) { %>
            <div class="commit-list">
                <h4>Recent Commits</h4>
                <ul>
                    <% if (typeof gitCommits !== 'undefined' && gitCommits) { %>
                        <% gitCommits.forEach((commit) => { %>
                        <li>
                            <button type="button" data-commit="<%= commit.hash %>">
                                <span class="commit-hash"><%= commit.hash.slice(0, 7) %></span>
                                <span class="commit-message"><%= commit.message %></span>
                            </button>
                        </li>
                        <% }); %>
                    <% } else { %>
                    <li><span class="commit-message">No commits found in git log.</span></li>
                    <% } %>
                </ul>
            </div>
            <% } %>
            <% if (typeof projectDir === 'string' && projectDir.trim()) { %>
            <div class="file-list">
                <h4>Files Changed</h4>
                <ul>
                    <% if (typeof diffOutput === 'string' && diffOutput.trim()) { %>
                        <% structuredDiff.forEach((file) => { %>
                        <% const fileLabel = file.path; %>
                        <li>
                            <button type="button" data-file="<%= file.name %>" class="file-item" data-repo="<%= gitRepoNameCLI %>">
                                <span class="file-label"><%= fileLabel %></span>
                                <span class="file-stats">
                                    <span class="additions"><%= file.additions > 0 ? '+' + file.additions : '' %></span>
                                    <span class="deletions"><%= file.deletions > 0 ? '-' + file.deletions : '' %></span>
                                </span>
                            </button>
                        </li>
                        <% }); %}
                    <% } else { %>
                    <li><span class="file-label">No changed files in diff output.</span></li>
                    <% } %>
                </ul>
            </div>
            <% } %>
        </div>

        <div class="diff-sidebar-resizer" id="diffSidebarResizer" role="separator" aria-label="Resize diff sidebar"></div>

        <div class="viewer-panel">
            <div class="file-meta">
                <span class="file-name" id="fileNameTitle"></span>
                <button class="open-in-editor-button" id="openInEditorButton" title="Open in editor">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        <path d="M18.5 2.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L18.5 2.5z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </button>
            </div>

            <div class="diff-view" id="diffView">
                <div class="diff-inner">
                    <% if (typeof diffOutput === 'string' && diffOutput.length) { %>
                        <%= diffOutput %>
                    <% } else { %>
                        <div class="diff-file-section">
                            <div class="diff-file-header">
                                <span class="diff-file-title">No diff available</span>
                            </div>
                            <div class="diff-file-viewer">
                                <div class="diff-lines">
                                    <div class="diff-line">
                                        <span class="line-num"></span>
                                        <span class="code">No diff available for this comparison.</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    <% } %>
                </div>
            </div>

            <div class="final-output-block" id="finalOutputBlock" hidden>
                <span class="final-output-label">Final Output</span>
                <pre class="final-output-text" id="finalOutputText"></pre>
            </div>

            <% if (projectDir) { %>
            <form class="diff-followup-form" id="diffFollowupForm">
                <label class="diff-followup-label" for="diffFollowupPrompt">Follow-up prompt</label>
                <textarea
                    id="diffFollowupPrompt"
                    class="diff-followup-input"
                    name="diffFollowupPrompt"
                    placeholder="Enter a follow-up prompt..."
                    rows="3"
                ></textarea>
                <div class="diff-followup-actions">
                    <span class="diff-followup-status" id="diffFollowupStatus" aria-live="polite"></span>
                    <button type="submit" class="diff-followup-submit" aria-label="Send follow-up">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M22 2L11 13M22 2L15 22L11 13M22 2L11 13" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    </button>
                </div>
            </form>
            <% } %>
        </div>
    </div>
</div>
<script>
    (function () {
        // Submit-on-enter handler for diff followup prompt
        // Using the setting from model_only.ejs to maintain consistency
        const form = document.getElementById("diffFollowupForm");
        const input = document.getElementById("diffFollowupPrompt");
        
        if (form && input) {
            // The submitOnEnter setting is received from parent window via postMessage
            let submitOnEnterEnabled = true;
            
            // Listen for submitOnEnter setting changes from the parent window
            window.addEventListener('message', function(event) {
                try {
                    if (event.data && event.data.type === 'sterling:settings' && event.data.key === 'submitOnEnter') {
                        submitOnEnterEnabled = event.data.value === true || event.data.value === 'true';
                    }
                } catch (e) {
                    // Silently ignore errors in event handling
                }
            });
            
            // Initialize with default value if no setting received
            try {
                // Try to get from localStorage (as a fallback)
                const submitOnEnterFromLocal = localStorage.getItem('submitOnEnter');
                if (submitOnEnterFromLocal !== null) {
                    submitOnEnterEnabled = submitOnEnterFromLocal === 'true';
                }
            } catch (e) {
                // Ignore localStorage errors
            }
            
            // Handle Enter key submission for followup prompt
            input.addEventListener("keydown", function(event) {
                try {
                    if (event.key === "Enter") {
                        if (event.shiftKey) {
                            // Allow Shift+Enter to insert a newline in the textarea.
                            return;
                        }
                        
                        // Check if submit-on-enter is currently enabled
                        if (!submitOnEnterEnabled) {
                            // If disabled, do nothing special (allow newline insertion)
                            return;
                        }
                        
                        // Prevent default to stop the textarea from adding a newline
                        // and instead submit the form.
                        event.preventDefault();
                        
                        // Simulate form submission
                        form.dispatchEvent(new Event('submit'));
                    }
                } catch (e) {
                    // Silently ignore errors in key handling
                }
            });
            
            // Handle form submission (copied from the original code)
            const setStatus = (message) => {
                const status = document.getElementById("diffFollowupStatus");
                if (!status) return;
                status.textContent = message || "";
            };
            
            form.addEventListener("submit", (event) => {
                event.preventDefault();
                const prompt = typeof input.value === "string" ? input.value.trim() : "";
                if (!prompt) {
                    setStatus("Enter a follow-up prompt to continue.");
                    return;
                }
                if (!window.parent || window.parent === window) {
                    setStatus("Follow-ups are available from the running task view.");
                    return;
                }
                try {
                    window.parent.postMessage({ type: "STERLING_VIEW_DIFF_MODAL_FOLLOWUP", prompt }, "*");
                    input.value = "";
                    setStatus("Follow-up sent.");
                } catch (_err) {
                    setStatus("Unable to send follow-up.");
                }
            });
        }
    })();
</script>
<script>
    (function () {
        const MERGE_BUTTON_ID = "mergeButton";
        const MERGE_REQUEST_MESSAGE_TYPE = "STERLING_VIEW_DIFF_MODAL_MERGE_REQUEST";
        const mergeButton = document.getElementById(MERGE_BUTTON_ID);
        if (!mergeButton) {
            return;
        }
        mergeButton.addEventListener("click", () => {
            if (mergeButton.disabled) {
                return;
            }
            if (!window.parent || window.parent === window) {
                return;
            }
            try {
                window.parent.postMessage({ type: MERGE_REQUEST_MESSAGE_TYPE }, '*');
            } catch (_err) { /* ignore */ }
        });
    })();
</script>
<% } %>
</body>
</html>