# Sample environment variables for AlfeCode
# Copy this file to `.env` and edit values as needed.

# Toggle the Editor page. Set to 'true' to enable, 'false' to disable.
# Accepts: 1/0, true/false, yes/no, on/off (case-insensitive)
EDITOR_ENABLED=true

# Toggle pricing display on the model-only model dropdown.
# Accepts: true/false (case-insensitive). Defaults to false.
MODEL_ONLY_SHOW_COSTS=false

# Control optional per-task QEMU VM spawn.
# Set to 'true' to allow ?vm=1 to spawn a VM; default is false (off).
# Accepts: 1/0, true/false, yes/no, on/off (case-insensitive)
ALFECODE_SPAWN_VM_PER_TASK=false

# Toggle the model dropdown element on the /agent page.
# Set to 'true' to hide the model dropdown; default is false (visible).
# Accepts: 1/0, true/false, yes/no, on/off (case-insensitive)
AGENT_MODEL_DROPDOWN_DISABLED=false

# Toggle the File Tree button on the /agent page.
# Set to 'true' to show the File Tree button; default is true (visible).
# Accepts: 1/0, true/false, yes/no, on/off (case-insensitive)
FILE_TREE_BUTTON_VISIBLE=true

# Toggle the Backlog button on the codex runner sidebar and access to /ProjectView.
# Set to 'true' to show the Backlog button; default is true (visible).
# Accepts: 1/0, true/false, yes/no, on/off (case-insensitive)
BACKLOG_BUTTON_VISIBLE=true

# LiteLLM proxy host used for generating per-user virtual keys.
LITELLM_HOST="https://litellm.alfe.sh"

# LiteLLM master key used by the backend to call /key/generate.
# Never expose this value to frontend clients.
LITELLM_MASTER_KEY=""

# Toggle the display of the pencil edit icon and editor link in the diff view.
# Set to 'true' to hide the editor link and icon; default is false (show).
# Accepts: 1/0, true/false, yes/no, on/off (case-insensitive)
HIDE_DIFF_FILE_EDIT=false

# Separated frontend/backend mode:
# Browser-visible backend origin used by frontend JS for API/SSE calls.
BACKEND_ORIGIN=""

# Frontend origin accepted by backend CORS.
FRONTEND_ORIGIN=""

# Serve static assets from backend (legacy single-server mode). Default false.
SERVE_FRONTEND_FROM_BACKEND=false

# Use SameSite=None; Secure session cookies for cross-site frontend/backend deployments.
ENABLE_CROSS_SITE_COOKIES=false
