# Rename this file to .env and update values for your environment.

GIT_SERVER_API_TOKEN=paste_generated_token_here
GIT_SERVER_API_HOST=0.0.0.0
GIT_SERVER_API_PORT=4005

# Serve the GitServer admin UI over HTTPS (recommended) on port 443.
GIT_SERVER_ADMIN_HTTPS_ENABLED=true
GIT_SERVER_ADMIN_HTTPS_PORT=443
# Optional: set if the public admin hostname differs from the inbound Host header.
# GIT_SERVER_ADMIN_HTTPS_HOST=git.example.com
# Required when HTTPS is enabled.
# GIT_SERVER_ADMIN_TLS_KEY_PATH=/etc/letsencrypt/live/git.example.com/privkey.pem
# GIT_SERVER_ADMIN_TLS_CERT_PATH=/etc/letsencrypt/live/git.example.com/fullchain.pem

GIT_DAEMON_LISTEN_HOST=0.0.0.0
GIT_DAEMON_PORT=9418
GIT_DAEMON_PUBLIC_HOST=<public-hostname-or-ip>
# Optional: only set if public port differs from GIT_DAEMON_PORT.
# GIT_DAEMON_PUBLIC_PORT=9418

# Optional: customize where bare repositories are created.
# GIT_SERVER_REPO_ROOT=./data/repositories
